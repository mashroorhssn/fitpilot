{
  "name": "fitpilot-backend",
  "version": "1.0.0",
  "description": "FitPilot - multi-agent AI fitness coach (Express + LangChain + Gemini)",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed:supabase": "ts-node src/scripts/seed.ts"
  },
  "dependencies": {
    "@langchain/core": "0.3.42",
    "@langchain/google-genai": "0.1.11",
    "@supabase/supabase-js": "^2.49.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nodemailer": "^6.10.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.4",
    "@types/nodemailer": "^6.4.17",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "zod": "3.23.8",
    "zod-to-json-schema": "3.23.5"
  }
}